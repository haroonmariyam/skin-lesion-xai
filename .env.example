# Copy this file to ".env" and fill in your real key.
# The ".env" file is gitignored so your secret is never committed.
#
# Get your key from: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Optional: name of the W&B project these runs are grouped under.
WANDB_PROJECT=skin-lesion-xai
